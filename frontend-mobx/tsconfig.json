{
  "extends": "../frontend/tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"],
      "@state/hooks": ["./src/state/hooks"]
    }
  },
  "include": ["src", "../frontend/src", "../shared/**/*.ts"],
  "exclude": ["../frontend/src/context/**/*", "../frontend/src/hooks/**/*"]
}
